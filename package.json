{
  "name": "kickoff-lock-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:e2e": "bun scripts/run-e2e.mjs",
    "test:e2e:seal": "bun scripts/run-seal-e2e.mjs",
    "brand:assets": "bun scripts/build-brand-assets.mjs",
    "verify:acceptance": "bun scripts/run-acceptance-evidence.mjs",
    "verify:production": "bun scripts/run-production-evidence.mjs",
    "production:bootstrap": "bun scripts/run-production-bootstrap.mjs",
    "access:preflight": "bun scripts/run-production-access-preflight.mjs",
    "doctor:production": "bun scripts/run-production-doctor.mjs",
    "collect:production": "bun scripts/run-production-acceptance-collector.mjs",
    "deploy:evidence": "bun scripts/run-public-deployment-evidence.mjs",
    "goal:audit": "bun scripts/run-production-goal-audit.mjs",
    "env:production": "bun scripts/run-production-env-merge.mjs",
    "env:production:plan": "bun scripts/run-production-env-plan.mjs",
    "secrets:handoff": "bun scripts/run-production-secrets-handoff.mjs",
    "runtime:config": "bun scripts/write-runtime-config.mjs",
    "runtime:config:check": "bun scripts/write-runtime-config.mjs --strict --json --no-write",
    "supabase:bootstrap": "bun scripts/run-supabase-production-bootstrap.mjs",
    "supabase:schema:check": "bun scripts/apply-supabase-schema.mjs --dry-run",
    "supabase:schema:apply": "bun scripts/apply-supabase-schema.mjs",
    "account:cloud-evidence": "bun scripts/run-account-cloud-sync-evidence.mjs",
    "doctor:supabase": "bun scripts/run-supabase-production-doctor.mjs",
    "doctor:filecoin": "bun scripts/run-filecoin-production-doctor.mjs",
    "filecoin:api:check": "bun scripts/check-filecoin-seal-api.mjs",
    "filecoin:bootstrap": "bun scripts/run-filecoin-production-bootstrap.mjs",
    "doctor:data": "bun scripts/run-data-production-doctor.mjs",
    "data:bootstrap": "bun scripts/run-data-production-bootstrap.mjs",
    "data:providers:check": "bun scripts/check-data-providers.mjs",
    "doctor:sharing": "bun scripts/run-sharing-production-doctor.mjs",
    "sharing:bootstrap": "bun scripts/run-sharing-production-bootstrap.mjs",
    "leaderboard:bootstrap": "bun scripts/run-leaderboard-production-bootstrap.mjs",
    "public:fixtures": "bun scripts/build-public-fixtures.mjs",
    "data:proxy:check": "bunx wrangler deploy --dry-run --config wrangler.data-proxy.jsonc",
    "data:proxy:deploy": "bunx wrangler deploy --config wrangler.data-proxy.jsonc",
    "pages:functions:build": "bunx wrangler pages functions build functions --outfile=.wrangler/pages-functions.js",
    "pages:cf:dev": "bun run build && bunx wrangler pages dev dist --compatibility-date=2026-07-05",
    "pages:cf:preflight": "bun scripts/run-cloudflare-pages-preflight.mjs",
    "pages:cf:check": "bun scripts/deploy-cloudflare-pages.mjs --check --skip-build",
    "pages:cf:deploy": "bun scripts/deploy-cloudflare-pages.mjs",
    "scout:data-targets": "bun scripts/run-data-target-scout.mjs",
    "share:production-image": "bun scripts/run-share-image-target.mjs",
    "capture:submission-assets": "bun scripts/capture-submission-assets.mjs",
    "share:upload-image": "bun scripts/run-share-image-upload.mjs",
    "seed:production-targets": "bun scripts/run-production-target-seed.mjs",
    "deploy:pages": "bun scripts/deploy-gh-pages.mjs",
    "pages:rebuild": "bun scripts/request-pages-build.mjs",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1",
    "seal:synapse": "bun scripts/seal-with-synapse.mjs",
    "seal:api": "bun server/filecoin-seal-api.mjs",
    "seal:api:mock": "FILECOIN_SEAL_MOCK=1 bun server/filecoin-seal-api.mjs",
    "seal:production-targets": "bun scripts/run-filecoin-target-seal.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "typescript": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0",
    "@filoz/synapse-sdk": "^0.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.9"
  }
}
